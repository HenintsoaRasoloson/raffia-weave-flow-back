# Environment variables declared in this file are NOT automatically loaded by Prisma.
# Please add `import "dotenv/config";` to your `prisma.config.ts` file, or use the Prisma CLI with Bun
# to load environment variables from .env files: https://pris.ly/prisma-config-env-vars.

# Prisma supports the native connection string format for PostgreSQL, MySQL, SQLite, SQL Server, MongoDB and CockroachDB.
# See the documentation for all the connection string options: https://pris.ly/d/connection-strings

DATABASE_URL=postgres://postgres:root@localhost:5432/raffia-weave

CORS_ORIGINS=http://localhost:5173,https://app.tondomaine.com

PORT=3000
PUBLIC_API_URL=http://localhost:3000
SWAGGER_PATH=docs
SWAGGER_USER=admin
SWAGGER_PASSWORD=change-me
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-too
ADMIN_NAME=Administrator

# Auth JWT (required outside development/test)
AUTH_JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
AUTH_JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
AUTH_JWT_ACCESS_TTL=15m
AUTH_JWT_REFRESH_TTL=7d
AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_LOCK_MINUTES=15

# GED / MinIO (S3 compatible)
MINIO_ENABLED=false
MINIO_ENDPOINT=http://localhost:9000
MINIO_REGION=us-east-1
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_RAW=ged-raw
MINIO_BUCKET_RENDERED=ged-rendered
MINIO_BUCKET_ARCHIVE=ged-archive
MINIO_FORCE_PATH_STYLE=true

# Cache (in-memory CacheModule; Redis optional later)
# Company settings TTL: 120s — Dashboard TTL: 30s
# CACHE_TTL_COMPANY_SETTINGS_MS=120000
# CACHE_TTL_DASHBOARD_MS=30000
# REDIS_URL=