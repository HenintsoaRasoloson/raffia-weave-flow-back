// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ClientType {
  B2B
  B2C
}

enum ClientStatus {
  ACTIVE
  PROSPECT
  LOYAL
  INACTIVE
}

enum ProductStatus {
  ACTIVE
  LOW_STOCK
  OUT_OF_STOCK
  ARCHIVED
}

enum MaterialUnit {
  KG
  M2
  M
  PCS
  BOBBIN
}

enum SalesOrderStatus {
  QUOTE
  TO_PROCESS
  IN_PRODUCTION
  PREPARING
  SHIPPED
  DELIVERED
  INVOICED
  CANCELLED
}

enum ProductionStatus {
  PLANNED
  PREPARATION
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum ProductionStage {
  PREPARATION
  CROCHET
  WEAVING
  LEATHER
  FINISHING
  QUALITY_CONTROL
}

enum DeliveryStatus {
  PLANNED
  PREPARING
  IN_TRANSIT
  DELIVERED
  FAILED
  RETURNED
}

enum PurchaseOrderStatus {
  DRAFT
  CONFIRMED
  IN_TRANSIT
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
}

enum InvoiceType {
  PROFORMA
  DEPOSIT
  INTERMEDIATE
  FINAL
  CREDIT_NOTE
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  SENT
  PAID
  PARTIALLY_PAID
  OVERDUE
  CANCELLED
}

enum CatalogShareStatus {
  ACTIVE
  EXPIRED
  REVOKED
}

enum CalendarEventType {
  PRODUCTION
  DELIVERY
  PURCHASE
}

enum LedgerEntryType {
  INCOME
  EXPENSE
  TRANSFER
}

model User {
  id                  String    @id @default(cuid())
  email               String    @unique
  name                String?
  passwordHash        String
  refreshTokenHash    String?
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

model CompanySetting {
  id                  String   @id @default(cuid())
  companyName         String
  siret               String?
  vatNumber           String?
  iban                String?
  addressLine         String?
  city                String?
  postalCode          String?
  country             String?
  cgvText             String?
  autoSendInvoices    Boolean  @default(true)
  lowStockAlerts      Boolean  @default(true)
  aiDecisionSupport   Boolean  @default(true)
  darkMode            Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model Category {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Color {
  id        String           @id @default(cuid())
  name      String
  hex       String
  active    Boolean          @default(true)
  variants  ProductVariant[]
  bomItems  BomItem[]
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@unique([name, hex])
}

model Product {
  id               String              @id @default(cuid())
  ref              String              @unique
  name             String
  description      String?
  categoryId       String
  category         Category            @relation(fields: [categoryId], references: [id])
  basePrice        Decimal             @db.Decimal(12, 2)
  stockOnHand      Int                 @default(0)
  status           ProductStatus       @default(ACTIVE)
  variants         ProductVariant[]
  orderItems       SalesOrderItem[]
  productionOrders ProductionOrder[]
  bomItems         BomItem[]
  shareLinks       CatalogShareProduct[]
  invoiceItems     InvoiceItem[]
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
}

model ProductVariant {
  id               String              @id @default(cuid())
  sku              String?             @unique
  productId        String
  product          Product             @relation(fields: [productId], references: [id])
  colorId          String?
  color            Color?              @relation(fields: [colorId], references: [id])
  name             String?
  stockOnHand      Int                 @default(0)
  priceOverride    Decimal?            @db.Decimal(12, 2)
  active           Boolean             @default(true)
  orderItems       SalesOrderItem[]
  productionOrders ProductionOrder[]
  bomItems         BomItem[]
  invoiceItems     InvoiceItem[]
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
}

model Client {
  id            String            @id @default(cuid())
  name          String
  type          ClientType
  status        ClientStatus      @default(ACTIVE)
  email         String?
  phone         String?
  contactName   String?
  siret         String?
  vatNumber     String?
  addressLine   String?
  city          String?
  postalCode    String?
  country       String?
  salesOrders   SalesOrder[]
  deliveries    Delivery[]
  invoices      Invoice[]
  shares        CatalogShare[]
  ledgerEntries LedgerEntry[]
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
}

model Supplier {
  id             String          @id @default(cuid())
  name           String          @unique
  country        String?
  category       String?
  email          String?
  phone          String?
  leadTimeDays   Int?
  qualityRating  Decimal?        @db.Decimal(2, 1)
  components     Component[]
  purchaseOrders PurchaseOrder[]
  ledgerEntries  LedgerEntry[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model Component {
  id                 String              @id @default(cuid())
  ref                String              @unique
  name               String
  unit               MaterialUnit
  stockQty           Decimal             @db.Decimal(14, 3)
  minQty             Decimal             @db.Decimal(14, 3)
  costPerUnit        Decimal?            @db.Decimal(12, 4)
  supplierId         String?
  supplier           Supplier?           @relation(fields: [supplierId], references: [id])
  bomItems           BomItem[]
  purchaseOrderItems PurchaseOrderItem[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
}

model BomItem {
  id          String          @id @default(cuid())
  productId   String
  product     Product         @relation(fields: [productId], references: [id])
  variantId   String?
  variant     ProductVariant? @relation(fields: [variantId], references: [id])
  componentId String
  component   Component       @relation(fields: [componentId], references: [id])
  colorId     String?
  color       Color?          @relation(fields: [colorId], references: [id])
  quantity    Decimal         @db.Decimal(14, 4)
  unitCost    Decimal?        @db.Decimal(12, 4)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@unique([productId, variantId, componentId, colorId])
}

model SalesOrder {
  id               String            @id @default(cuid())
  orderNumber      String            @unique
  clientId         String
  client           Client            @relation(fields: [clientId], references: [id])
  orderType        ClientType
  status           SalesOrderStatus  @default(TO_PROCESS)
  orderDate        DateTime
  productionOrders ProductionOrder[]
  items            SalesOrderItem[]
  deliveries       Delivery[]
  invoices         Invoice[]
  ledgerEntries    LedgerEntry[]
  calendarEvents   CalendarEvent[]
  totalHt          Decimal           @db.Decimal(12, 2)
  taxRate          Decimal           @default(20.00) @db.Decimal(5, 2)
  totalTtc         Decimal           @db.Decimal(12, 2)
  currency         String            @default("EUR")
  notes            String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

model SalesOrderItem {
  id               String           @id @default(cuid())
  salesOrderId     String
  salesOrder       SalesOrder       @relation(fields: [salesOrderId], references: [id])
  productId        String?
  product          Product?         @relation(fields: [productId], references: [id])
  variantId        String?
  variant          ProductVariant?  @relation(fields: [variantId], references: [id])
  description      String
  quantity         Int
  unitPriceHt      Decimal          @db.Decimal(12, 2)
  taxRate          Decimal          @default(20.00) @db.Decimal(5, 2)
  lineTotalHt      Decimal          @db.Decimal(12, 2)
  productionOrders ProductionOrder[]
  invoiceItems     InvoiceItem[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}

model ProductionOrder {
  id               String            @id @default(cuid())
  orderNumber      String            @unique
  salesOrderId     String?
  salesOrder       SalesOrder?       @relation(fields: [salesOrderId], references: [id])
  salesOrderItemId String?
  salesOrderItem   SalesOrderItem?   @relation(fields: [salesOrderItemId], references: [id])
  productId        String
  product          Product           @relation(fields: [productId], references: [id])
  variantId        String?
  variant          ProductVariant?   @relation(fields: [variantId], references: [id])
  quantity         Int
  startDate        DateTime?
  endDate          DateTime?
  progress         Int               @default(0)
  status           ProductionStatus  @default(PLANNED)
  stages           ProductionStep[]
  calendarEvents   CalendarEvent[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

model ProductionStep {
  id                String           @id @default(cuid())
  productionOrderId String
  productionOrder   ProductionOrder  @relation(fields: [productionOrderId], references: [id])
  stage             ProductionStage
  plannedStart      DateTime?
  plannedEnd        DateTime?
  actualStart       DateTime?
  actualEnd         DateTime?
  progress          Int              @default(0)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@unique([productionOrderId, stage])
}

model PurchaseOrder {
  id            String              @id @default(cuid())
  orderNumber   String              @unique
  supplierId    String
  supplier      Supplier            @relation(fields: [supplierId], references: [id])
  status        PurchaseOrderStatus @default(DRAFT)
  orderDate     DateTime
  expectedAt    DateTime?
  receivedAt    DateTime?
  items         PurchaseOrderItem[]
  ledgerEntries LedgerEntry[]
  calendarEvents CalendarEvent[]
  totalHt       Decimal             @db.Decimal(12, 2)
  currency      String              @default("EUR")
  notes         String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
}

model PurchaseOrderItem {
  id              String        @id @default(cuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  componentId     String?
  component       Component?    @relation(fields: [componentId], references: [id])
  description     String
  quantity        Decimal       @db.Decimal(14, 3)
  unitPrice       Decimal       @db.Decimal(12, 4)
  lineTotal       Decimal       @db.Decimal(12, 2)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model Delivery {
  id            String         @id @default(cuid())
  deliveryNumber String        @unique
  salesOrderId  String
  salesOrder    SalesOrder     @relation(fields: [salesOrderId], references: [id])
  clientId      String
  client        Client         @relation(fields: [clientId], references: [id])
  carrier       String?
  trackingCode  String?
  eta           DateTime?
  deliveredAt   DateTime?
  status        DeliveryStatus @default(PLANNED)
  notes         String?
  calendarEvents CalendarEvent[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Invoice {
  id            String         @id @default(cuid())
  invoiceNumber String         @unique
  type          InvoiceType
  status        InvoiceStatus  @default(DRAFT)
  salesOrderId  String?
  salesOrder    SalesOrder?    @relation(fields: [salesOrderId], references: [id])
  clientId      String
  client        Client         @relation(fields: [clientId], references: [id])
  issueDate     DateTime
  dueDate       DateTime?
  paidAt        DateTime?
  items         InvoiceItem[]
  subtotalHt    Decimal        @db.Decimal(12, 2)
  taxAmount     Decimal        @db.Decimal(12, 2)
  totalTtc      Decimal        @db.Decimal(12, 2)
  currency      String         @default("EUR")
  notes         String?
  ledgerEntries LedgerEntry[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model InvoiceItem {
  id               String           @id @default(cuid())
  invoiceId        String
  invoice          Invoice          @relation(fields: [invoiceId], references: [id])
  salesOrderItemId String?
  salesOrderItem   SalesOrderItem?  @relation(fields: [salesOrderItemId], references: [id])
  productId        String?
  product          Product?         @relation(fields: [productId], references: [id])
  variantId        String?
  variant          ProductVariant?  @relation(fields: [variantId], references: [id])
  description      String
  quantity         Int
  unitPriceHt      Decimal          @db.Decimal(12, 2)
  taxRate          Decimal          @default(20.00) @db.Decimal(5, 2)
  lineTotalHt      Decimal          @db.Decimal(12, 2)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}

model CatalogShare {
  id           String              @id @default(cuid())
  token        String              @unique
  title        String
  clientId     String?
  client       Client?             @relation(fields: [clientId], references: [id])
  status       CatalogShareStatus  @default(ACTIVE)
  expiresAt    DateTime?
  viewCount    Int                 @default(0)
  lastViewedAt DateTime?
  products     CatalogShareProduct[]
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
}

model CatalogShareProduct {
  id             String       @id @default(cuid())
  catalogShareId String
  catalogShare   CatalogShare @relation(fields: [catalogShareId], references: [id])
  productId      String
  product        Product      @relation(fields: [productId], references: [id])

  @@unique([catalogShareId, productId])
}

model CalendarEvent {
  id                String            @id @default(cuid())
  eventType         CalendarEventType
  label             String
  eventDate         DateTime
  salesOrderId      String?
  salesOrder        SalesOrder?       @relation(fields: [salesOrderId], references: [id])
  productionOrderId String?
  productionOrder   ProductionOrder?  @relation(fields: [productionOrderId], references: [id])
  purchaseOrderId   String?
  purchaseOrder     PurchaseOrder?    @relation(fields: [purchaseOrderId], references: [id])
  deliveryId        String?
  delivery          Delivery?         @relation(fields: [deliveryId], references: [id])
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
}

model LedgerEntry {
  id              String          @id @default(cuid())
  entryDate       DateTime
  label           String
  entryType       LedgerEntryType
  amount          Decimal         @db.Decimal(12, 2)
  currency        String          @default("EUR")
  clientId        String?
  client          Client?         @relation(fields: [clientId], references: [id])
  supplierId      String?
  supplier        Supplier?       @relation(fields: [supplierId], references: [id])
  salesOrderId    String?
  salesOrder      SalesOrder?     @relation(fields: [salesOrderId], references: [id])
  invoiceId       String?
  invoice         Invoice?        @relation(fields: [invoiceId], references: [id])
  purchaseOrderId String?
  purchaseOrder   PurchaseOrder?  @relation(fields: [purchaseOrderId], references: [id])
  notes           String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}
