// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ClientType {
  B2B
  B2C
}

enum ClientStatus {
  ACTIVE
  PROSPECT
  LOYAL
  INACTIVE
}

enum ProductStatus {
  ACTIVE
  LOW_STOCK
  OUT_OF_STOCK
  ARCHIVED
}

enum ProductSize {
  PM
  MM
  GM
}

enum MaterialUnit {
  KG
  M2
  M
  PCS
  BOBBIN
}

// Origine d'un composant/matière première :
// PURCHASED  = acheté à un fournisseur (ex: raphia brut, anneaux métal)
// MANUFACTURED = fabriqué en interne avant d'être utilisé (ex: plaque de raphia tressée, sangle découpée)
enum ComponentOrigin {
  PURCHASED
  MANUFACTURED
}

enum SalesOrderStatus {
  QUOTE
  TO_PROCESS
  IN_PRODUCTION
  PREPARING
  SHIPPED
  DELIVERED
  INVOICED
  CANCELLED
}

enum ProductionStatus {
  PLANNED
  PREPARATION
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum ProductionStage {
  PREPARATION
  CROCHET
  WEAVING
  LEATHER
  FINISHING
  QUALITY_CONTROL
}

enum DeliveryStatus {
  PLANNED
  PREPARING
  IN_TRANSIT
  DELIVERED
  FAILED
  RETURNED
}

enum PurchaseOrderStatus {
  DRAFT
  CONFIRMED
  IN_TRANSIT
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
}

// Types de factures dans le cycle de vente :
// PROFORMA      : facture estimative envoyée avant paiement acompte (non comptable)
// DEPOSIT       : facture d\'acompte (ex: 30% à la commande)
// INTERMEDIATE  : facture intermédiaire en cours de production (commandes longues)
// FINAL         : facture du solde final à la livraison
// CREDIT_NOTE   : avoir (remboursement partiel ou annulation)
enum InvoiceType {
  PROFORMA
  DEPOSIT
  INTERMEDIATE
  FINAL
  CREDIT_NOTE
}

// Mode de paiement utilisé par le client :
// CASH          : espèces
// BANK_TRANSFER : virement bancaire
// CHECK         : chèque
// MOBILE_MONEY  : paiement mobile (ex: Orange Money, MTN)
// CARD          : carte bancaire
enum PaymentMethod {
  CASH
  BANK_TRANSFER
  CHECK
  MOBILE_MONEY
  CARD
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  SENT
  PAID
  PARTIALLY_PAID
  OVERDUE
  CANCELLED
}

enum InvoiceDocumentKind {
  SIGNED
  STAMPED
  SIGNED_AND_STAMPED
  OTHER
}

enum BatDocumentKind {
  PREVIEW
  SENT_TO_CLIENT
  APPROVED_SIGNED
  OTHER
}

enum CompressionAlgo {
  NONE
  GZIP
}

enum ProductTechnicalElementCategory {
  CROCHET
  RAPHIA
  LEATHER
  ACCESSORY
  LINING
  HANDLE
  HARDWARE
  LABEL
  PACKAGING
  OTHER
}

enum CatalogShareStatus {
  ACTIVE
  EXPIRED
  REVOKED
}

enum CalendarEventType {
  PRODUCTION
  DELIVERY
  PURCHASE
}

enum LedgerEntryType {
  INCOME
  EXPENSE
  TRANSFER
}

enum UserRole {
  GERANT
  RESPONSABLE_GENERAL
  RESPONSABLE_PRODUCTION
  RESPONSABLE_LIVRAISON
  RESPONSABLE_FINANCIER_STOCKS
}

// Actions auditables : qui a fait quoi, quand, et sur quelle entité
enum AuditAction {
  // Commandes
  SALES_ORDER_CREATED
  SALES_ORDER_STATUS_CHANGED
  SALES_ORDER_BAT_SENT
  SALES_ORDER_BAT_APPROVED
  // Factures
  INVOICE_CREATED
  INVOICE_PAYMENT_RECORDED
  INVOICE_MARKED_PAID
  // Production
  PRODUCTION_ORDER_CREATED
  PRODUCTION_ORDER_PROGRESS_UPDATED
  PRODUCTION_ORDER_QUALITY_APPROVED
  // Achats
  PURCHASE_ORDER_CREATED
  PURCHASE_ORDER_STATUS_CHANGED
  // Livraisons
  DELIVERY_CREATED
  DELIVERY_MARKED_DELIVERED
}

model User {
  id                  String    @id @default(cuid())
  email               String    @unique
  name                String?
  role                UserRole  @default(RESPONSABLE_PRODUCTION)
  isAdmin             Boolean   @default(false)
  passwordHash        String
  refreshTokenHash    String?
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?
  auditLogs           AuditLog[]
  uploadedProductImages ProductImage[]
  uploadedBatDocuments BatDocument[]
  uploadedClientFiscalCards ClientFiscalCard[]
  uploadedInvoiceDocuments InvoiceDocument[]
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

// Journal d'audit : enregistre chaque action sur les entités critiques.
// Permet de tracer qui a créé/modifié quoi et quand.
model AuditLog {
  id          String       @id @default(cuid())
  entityType  String       // ex: SalesOrder, Invoice, ProductionOrder
  entityId    String       // l'ID de l'entité
  action      AuditAction
  userId      String
  user        User         @relation(fields: [userId], references: [id])
  changes     Json?        // {before: {...}, after: {...}} les champs modifiés
  details     String?      // description libre (raison, référence, etc.)
  createdAt   DateTime     @default(now())

  @@index([entityType, entityId])
  @@index([userId])
  @@index([createdAt])
}

model CompanySetting {
  id                  String   @id @default(cuid())
  companyName         String
  siret               String?
  vatNumber           String?
  iban                String?
  addressLine         String?
  city                String?
  postalCode          String?
  country             String?
  cgvText             String?
  autoSendInvoices    Boolean  @default(true)
  lowStockAlerts      Boolean  @default(true)
  aiDecisionSupport   Boolean  @default(true)
  darkMode            Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model Category {
  id        String    @id @default(cuid())
  name      String
  code      String?   @unique
  refSequenceLength Int @default(6)
  refNextSequence  Int @default(1)
  slug      String    @unique
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Color {
  id        String           @id @default(cuid())
  name      String
  hex       String
  active    Boolean          @default(true)
  variants  ProductVariant[]
  bomItems  BomItem[]
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@unique([name, hex])
}

model Product {
  id               String              @id @default(cuid())
  ref              String              @unique
  name             String
  description      String?
  categoryId       String
  category         Category            @relation(fields: [categoryId], references: [id])
  basePrice        Decimal             @db.Decimal(12, 2)
  stockOnHand      Int                 @default(0)
  status           ProductStatus       @default(ACTIVE)
  variants         ProductVariant[]
  orderItems       SalesOrderItem[]
  productionOrders ProductionOrder[]
  bomItems         BomItem[]
  shareLinks       CatalogShareProduct[]
  invoiceItems     InvoiceItem[]
  productImages    ProductImage[]
  technicalSheet   ProductTechnicalSheet?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
}

model ProductTechnicalSheet {
  id            String                        @id @default(cuid())
  productId     String                        @unique
  product       Product                       @relation(fields: [productId], references: [id])
  version       Int                           @default(1)
  title         String?
  workshopNotes String?
  instructions  String?
  elements      ProductTechnicalSheetElement[]
  createdAt     DateTime                      @default(now())
  updatedAt     DateTime                      @updatedAt
}

model ProductTechnicalSheetElement {
  id               String                         @id @default(cuid())
  technicalSheetId String
  technicalSheet   ProductTechnicalSheet          @relation(fields: [technicalSheetId], references: [id])
  sequence         Int                            @default(1)
  name             String
  category         ProductTechnicalElementCategory @default(OTHER)
  componentType    String?
  material         String?
  color            String?
  dimensions       String?
  sizeLabel        String?
  quantity         Decimal?                       @db.Decimal(14, 4)
  unit             MaterialUnit?
  isOptional       Boolean                        @default(false)
  notes            String?
  createdAt        DateTime                       @default(now())
  updatedAt        DateTime                       @updatedAt

  @@index([technicalSheetId, sequence])
}

model ProductImage {
  id              String          @id @default(cuid())
  productId       String
  product         Product         @relation(fields: [productId], references: [id])
  originalName    String
  mimeType        String
  bucket          String?
  objectKey       String?
  storagePath     String?
  originalSize    Int
  compressedSize  Int
  compressionAlgo CompressionAlgo @default(GZIP)
  uploadedById    String?
  uploadedBy      User?           @relation(fields: [uploadedById], references: [id], onDelete: SetNull)
  createdAt       DateTime        @default(now())

  @@index([productId])
}

model ProductVariant {
  id               String              @id @default(cuid())
  sku              String?             @unique
  productId        String
  product          Product             @relation(fields: [productId], references: [id])
  colorId          String?
  color            Color?              @relation(fields: [colorId], references: [id])
  size             ProductSize         @default(MM)
  defaultDimensions String?
  name             String?
  stockOnHand      Int                 @default(0)
  priceOverride    Decimal?            @db.Decimal(12, 2)
  active           Boolean             @default(true)
  orderItems       SalesOrderItem[]
  productionOrders ProductionOrder[]
  bomItems         BomItem[]
  invoiceItems     InvoiceItem[]
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  @@index([productId, size])
}

model Client {
  id            String            @id @default(cuid())
  name          String
  type          ClientType
  status        ClientStatus      @default(ACTIVE)
  email         String?
  phone         String?
  contactName   String?
  siret         String?
  vatNumber     String?
  addressLine   String?
  city          String?
  postalCode    String?
  country       String?
  salesOrders   SalesOrder[]
  deliveries    Delivery[]
  invoices      Invoice[]
  shares        CatalogShare[]
  fiscalCards   ClientFiscalCard[]
  ledgerEntries LedgerEntry[]
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
}

model ClientFiscalCard {
  id              String          @id @default(cuid())
  clientId        String
  client          Client          @relation(fields: [clientId], references: [id])
  originalName    String
  mimeType        String
  bucket          String?
  objectKey       String?
  storagePath     String?
  originalSize    Int
  compressedSize  Int
  compressionAlgo CompressionAlgo @default(GZIP)
  validUntil      DateTime
  uploadedById    String?
  uploadedBy      User?           @relation(fields: [uploadedById], references: [id], onDelete: SetNull)
  createdAt       DateTime        @default(now())

  @@index([clientId])
  @@index([clientId, validUntil])
}

model Supplier {
  id             String          @id @default(cuid())
  name           String          @unique
  country        String?
  category       String?
  email          String?
  phone          String?
  leadTimeDays   Int?
  qualityRating  Decimal?        @db.Decimal(2, 1)
  components     Component[]
  purchaseOrders PurchaseOrder[]
  ledgerEntries  LedgerEntry[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model Component {
  id                 String            @id @default(cuid())
  ref                String            @unique
  name               String
  unit               MaterialUnit
  // PURCHASED  : raphia brut, anneaux métal, sangles achetées → liés à un fournisseur
  // MANUFACTURED : plaque de raphia, sangle découpée → fabriqués en interne (supplierId = null)
  origin             ComponentOrigin   @default(PURCHASED)
  stockQty           Decimal           @db.Decimal(14, 3)
  minQty             Decimal           @db.Decimal(14, 3)
  costPerUnit        Decimal?          @db.Decimal(12, 4)
  supplierId         String?
  supplier           Supplier?         @relation(fields: [supplierId], references: [id])
  bomItems           BomItem[]
  purchaseOrderItems PurchaseOrderItem[]
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
}

// BOM = Bill of Materials (Nomenclature de fabrication)
// Chaque ligne BomItem décrit UNE matière première nécessaire pour fabriquer UN produit.
// Exemple — Nomenclature du "Sac raphia naturel M" :
//   BomItem 1 : componentId=raphia-brut,   quantity=0.5  (unité KG)
//   BomItem 2 : componentId=plaque-raphia, quantity=2    (unité PCS)
//   BomItem 3 : componentId=sangle-cuir,   quantity=1    (unité M)
//   BomItem 4 : componentId=anneau-metal,  quantity=2    (unité PCS)
// → Lors d'un ordre de production de 10 sacs, le système consomme automatiquement :
//     5 kg raphia brut, 20 plaques, 10m sangle, 20 anneaux
model BomItem {
  id          String          @id @default(cuid())
  productId   String
  product     Product         @relation(fields: [productId], references: [id])
  variantId   String?         // optionnel : si la nomenclature diffère selon la variante (couleur, taille)
  variant     ProductVariant? @relation(fields: [variantId], references: [id])
  componentId String
  component   Component       @relation(fields: [componentId], references: [id])
  colorId     String?         // optionnel : spécifie la couleur du composant si applicable
  color       Color?          @relation(fields: [colorId], references: [id])
  quantity    Decimal         @db.Decimal(14, 4) // quantité nécessaire par unité de produit fini
  unitCost    Decimal?        @db.Decimal(12, 4) // coût unitaire snapshot au moment de la création
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@unique([productId, variantId, componentId, colorId])
}

model SalesOrder {
  id               String            @id @default(cuid())
  orderNumber      String            @unique
  clientId         String
  client           Client            @relation(fields: [clientId], references: [id])
  orderType        ClientType
  status           SalesOrderStatus  @default(TO_PROCESS)
  orderDate        DateTime
  // BAT = Bon à Tirer : validation du client sur le modèle/prototype avant lancement prod.
  // batRequired = true  → le passage en IN_PRODUCTION est bloqué tant que batApprovedAt = null
  // Exemple : client valide la couleur, la dimension et les finitions du sac avant fabrication
  batRequired      Boolean           @default(false)
  batSentAt        DateTime?         // date d\'envoi du modèle/visuel au client
  batApprovedAt    DateTime?         // date de validation client
  batDocuments     BatDocument[]
  productionOrders ProductionOrder[]
  items            SalesOrderItem[]
  deliveries       Delivery[]
  invoices         Invoice[]
  ledgerEntries    LedgerEntry[]
  calendarEvents   CalendarEvent[]
  totalHt          Decimal           @db.Decimal(12, 2)
  taxRate          Decimal           @default(20.00) @db.Decimal(5, 2)
  totalTtc         Decimal           @db.Decimal(12, 2)
  currency         String            @default("EUR")
  notes            String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

model BatDocument {
  id              String          @id @default(cuid())
  salesOrderId    String
  salesOrder      SalesOrder      @relation(fields: [salesOrderId], references: [id])
  kind            BatDocumentKind @default(PREVIEW)
  originalName    String
  mimeType        String
  bucket          String?
  objectKey       String?
  storagePath     String?
  originalSize    Int
  compressedSize  Int
  compressionAlgo CompressionAlgo @default(NONE)
  uploadedById    String?
  uploadedBy      User?           @relation(fields: [uploadedById], references: [id], onDelete: SetNull)
  createdAt       DateTime        @default(now())

  @@index([salesOrderId])
  @@index([salesOrderId, kind])
}

model SalesOrderItem {
  id               String           @id @default(cuid())
  salesOrderId     String
  salesOrder       SalesOrder       @relation(fields: [salesOrderId], references: [id])
  productId        String?
  product          Product?         @relation(fields: [productId], references: [id])
  variantId        String?
  variant          ProductVariant?  @relation(fields: [variantId], references: [id])
  description      String
  quantity         Int
  unitPriceHt      Decimal          @db.Decimal(12, 2)
  taxRate          Decimal          @default(20.00) @db.Decimal(5, 2)
  lineTotalHt      Decimal          @db.Decimal(12, 2)
  productionOrders ProductionOrder[]
  invoiceItems     InvoiceItem[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}

model ProductionOrder {
  id               String            @id @default(cuid())
  orderNumber      String            @unique
  salesOrderId     String?
  salesOrder       SalesOrder?       @relation(fields: [salesOrderId], references: [id])
  salesOrderItemId String?
  salesOrderItem   SalesOrderItem?   @relation(fields: [salesOrderItemId], references: [id])
  productId        String
  product          Product           @relation(fields: [productId], references: [id])
  variantId        String?
  variant          ProductVariant?   @relation(fields: [variantId], references: [id])
  quantity         Int
  startDate        DateTime?
  endDate          DateTime?
  progress         Int               @default(0)
  status           ProductionStatus  @default(PLANNED)
  // Validation qualité : passe à true après contrôle conformité (avant livraison)
  qualityApproved  Boolean           @default(false)
  stages           ProductionStep[]
  calendarEvents   CalendarEvent[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

model ProductionStep {
  id                String           @id @default(cuid())
  productionOrderId String
  productionOrder   ProductionOrder  @relation(fields: [productionOrderId], references: [id])
  stage             ProductionStage
  plannedStart      DateTime?
  plannedEnd        DateTime?
  actualStart       DateTime?
  actualEnd         DateTime?
  progress          Int              @default(0)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@unique([productionOrderId, stage])
}

model PurchaseOrder {
  id            String              @id @default(cuid())
  orderNumber   String              @unique
  supplierId    String
  supplier      Supplier            @relation(fields: [supplierId], references: [id])
  status        PurchaseOrderStatus @default(DRAFT)
  orderDate     DateTime
  expectedAt    DateTime?
  receivedAt    DateTime?
  items         PurchaseOrderItem[]
  ledgerEntries LedgerEntry[]
  calendarEvents CalendarEvent[]
  totalHt       Decimal             @db.Decimal(12, 2)
  currency      String              @default("EUR")
  notes         String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
}

model PurchaseOrderItem {
  id              String        @id @default(cuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  componentId     String?
  component       Component?    @relation(fields: [componentId], references: [id])
  description     String
  quantity        Decimal       @db.Decimal(14, 3)
  unitPrice       Decimal       @db.Decimal(12, 4)
  lineTotal       Decimal       @db.Decimal(12, 2)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model Delivery {
  id            String         @id @default(cuid())
  deliveryNumber String        @unique
  salesOrderId  String
  salesOrder    SalesOrder     @relation(fields: [salesOrderId], references: [id])
  clientId      String
  client        Client         @relation(fields: [clientId], references: [id])
  carrier       String?
  trackingCode  String?
  eta           DateTime?
  deliveredAt   DateTime?
  status        DeliveryStatus @default(PLANNED)
  notes         String?
  calendarEvents CalendarEvent[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Invoice {
  id            String         @id @default(cuid())
  invoiceNumber String         @unique
  type          InvoiceType
  status        InvoiceStatus  @default(DRAFT)
  salesOrderId  String?
  salesOrder    SalesOrder?    @relation(fields: [salesOrderId], references: [id])
  clientId      String
  client        Client         @relation(fields: [clientId], references: [id])
  issueDate     DateTime
  dueDate       DateTime?
  paidAt        DateTime?
  // Montant déjà encaissé (acompte + éventuels versements partiels)
  // PARTIALLY_PAID si paidAmount < totalTtc, PAID si paidAmount >= totalTtc
  paidAmount    Decimal?       @db.Decimal(12, 2)
  items         InvoiceItem[]
  payments      InvoicePayment[]
  subtotalHt    Decimal        @db.Decimal(12, 2)
  taxAmount     Decimal        @db.Decimal(12, 2)
  totalTtc      Decimal        @db.Decimal(12, 2)
  currency      String         @default("EUR")
  notes         String?
  documents     InvoiceDocument[]
  ledgerEntries LedgerEntry[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model InvoiceTemplate {
  id        String      @id @default(cuid())
  type      InvoiceType @unique
  name      String
  subject   String?
  body      String
  footer    String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

model InvoiceDocument {
  id           String              @id @default(cuid())
  invoiceId    String
  invoice      Invoice             @relation(fields: [invoiceId], references: [id])
  kind         InvoiceDocumentKind @default(SIGNED)
  originalName String
  storedName   String
  mimeType     String
  fileSize     Int
  storagePath  String?
  bucket       String?
  objectKey    String?
  originalSize Int?
  compressedSize Int?
  compressionAlgo CompressionAlgo @default(NONE)
  uploadedById String?
  uploadedBy   User?               @relation(fields: [uploadedById], references: [id], onDelete: SetNull)
  createdAt    DateTime            @default(now())

  @@index([invoiceId])
  @@index([invoiceId, kind])
}

model InvoiceItem {
  id               String           @id @default(cuid())
  invoiceId        String
  invoice          Invoice          @relation(fields: [invoiceId], references: [id])
  salesOrderItemId String?
  salesOrderItem   SalesOrderItem?  @relation(fields: [salesOrderItemId], references: [id])
  productId        String?
  product          Product?         @relation(fields: [productId], references: [id])
  variantId        String?
  variant          ProductVariant?  @relation(fields: [variantId], references: [id])
  description      String
  quantity         Int
  unitPriceHt      Decimal          @db.Decimal(12, 2)
  taxRate          Decimal          @default(20.00) @db.Decimal(5, 2)
  lineTotalHt      Decimal          @db.Decimal(12, 2)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}

// Historique des versements reçus sur une facture.
// Permet de tracer : acompte 30% par virement le J+1, solde 70% en espèces à la livraison.
model InvoicePayment {
  id            String         @id @default(cuid())
  invoiceId     String
  invoice       Invoice        @relation(fields: [invoiceId], references: [id])
  amount        Decimal        @db.Decimal(12, 2)
  paymentMethod PaymentMethod
  paidAt        DateTime       @default(now())
  notes         String?
  createdAt     DateTime       @default(now())
}

model CatalogShare {
  id           String              @id @default(cuid())
  token        String              @unique
  title        String
  clientId     String?
  client       Client?             @relation(fields: [clientId], references: [id])
  status       CatalogShareStatus  @default(ACTIVE)
  expiresAt    DateTime?
  viewCount    Int                 @default(0)
  lastViewedAt DateTime?
  products     CatalogShareProduct[]
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
}

model CatalogShareProduct {
  id             String       @id @default(cuid())
  catalogShareId String
  catalogShare   CatalogShare @relation(fields: [catalogShareId], references: [id])
  productId      String
  product        Product      @relation(fields: [productId], references: [id])

  @@unique([catalogShareId, productId])
}

model CalendarEvent {
  id                String            @id @default(cuid())
  eventType         CalendarEventType
  label             String
  eventDate         DateTime
  salesOrderId      String?
  salesOrder        SalesOrder?       @relation(fields: [salesOrderId], references: [id])
  productionOrderId String?
  productionOrder   ProductionOrder?  @relation(fields: [productionOrderId], references: [id])
  purchaseOrderId   String?
  purchaseOrder     PurchaseOrder?    @relation(fields: [purchaseOrderId], references: [id])
  deliveryId        String?
  delivery          Delivery?         @relation(fields: [deliveryId], references: [id])
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
}

model LedgerEntry {
  id              String          @id @default(cuid())
  entryDate       DateTime
  label           String
  entryType       LedgerEntryType
  amount          Decimal         @db.Decimal(12, 2)
  currency        String          @default("EUR")
  clientId        String?
  client          Client?         @relation(fields: [clientId], references: [id])
  supplierId      String?
  supplier        Supplier?       @relation(fields: [supplierId], references: [id])
  salesOrderId    String?
  salesOrder      SalesOrder?     @relation(fields: [salesOrderId], references: [id])
  invoiceId       String?
  invoice         Invoice?        @relation(fields: [invoiceId], references: [id])
  purchaseOrderId String?
  purchaseOrder   PurchaseOrder?  @relation(fields: [purchaseOrderId], references: [id])
  notes           String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}
